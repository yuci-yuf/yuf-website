rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin allowlist: a signed-in user is an admin ONLY if there is a document
    // at /admins/{their-uid}. Being authenticated is no longer sufficient — this
    // closes the hole where any Firebase Auth account (e.g. via an enabled
    // Google sign-in provider) would otherwise gain full admin access. Manage
    // the allowlist by hand in the Firebase console; docs are never client-
    // writable (see the /admins rule below). Mirrors contexts/AuthContext.tsx.
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // The allowlist itself. A signed-in user may read only their OWN entry (so
    // the client can tell whether it's an admin); nobody may write via a client
    // — entries are added/removed manually in the Firebase console.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Public CMS content ──
    // Anyone may read events, categories, and gallery (they drive the public
    // site). Only admins may create/update/delete them via the admin panel.
    match /events/{id} {
      allow read: if true;
      // Slot reservation + counter increments now run server-side via the
      // Firebase Admin SDK (which bypasses these rules), so clients get no
      // write access at all — only admins in the panel.
      allow write: if isAdmin();
    }
    match /eventCategories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /gallery/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Global site settings (e.g. the registration on/off switch). Public read so
    // the register page can reflect it; only admins may change it.
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Public submissions ──
    // Visitors may create a submission; only admins may read or modify them.
    match /contactSubmissions/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    // Registrations are CREATED only by the server (Admin SDK) so payment
    // status, amount, and the reserved slot can't be forged by clients. Admins
    // may still read/update (status changes) / delete from the panel.
    match /registrations/{id} {
      allow create: if false;
      allow read, update, delete: if isAdmin();
    }

    // Everything else is denied by default.
  }
}
