rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // Single-admin model: the admin account is the only one created in Firebase
    // Auth (email/password only — no public sign-up), so any signed-in user is
    // the admin. Matches the check in contexts/AuthContext.tsx.
    function isAdmin() {
      return request.auth != null;
    }

    // ── Public CMS content ──
    // Anyone may read events, categories, and gallery (they drive the public
    // site). Only admins may create/update/delete them via the admin panel.
    match /events/{id} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Admins may edit freely. The public registration flow may also update an
      // event, but ONLY to bump the registration counter by exactly one and
      // touch nothing else — this lets the capacity check + increment run in a
      // transaction without exposing any other field to anonymous writes.
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['registrationCount']) &&
        request.resource.data.registrationCount ==
          ((resource.data.registrationCount is number
            ? resource.data.registrationCount : 0) + 1)
      );
    }
    match /eventCategories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /gallery/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Public submissions ──
    // Visitors may create a submission; only admins may read or modify them.
    match /contactSubmissions/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /registrations/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Everything else is denied by default.
  }
}
